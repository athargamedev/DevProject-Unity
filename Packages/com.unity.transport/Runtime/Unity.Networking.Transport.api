        public static ref NetworkSettings WithSecureServerParameters(this ref NetworkSettings settings, string certificate, string privateKey, string caCertificate, string clientName, SecureClientAuthPolicy clientAuthenticationPolicy = SecureClientAuthPolicy.Required);
        public static ref NetworkSettings WithSecureServerParameters(this ref NetworkSettings settings, ref Unity.Collections.FixedString4096Bytes certificate, ref Unity.Collections.FixedString4096Bytes privateKey, ref Unity.Collections.FixedString4096Bytes caCertificate, ref Unity.Collections.FixedString512Bytes clientName, SecureClientAuthPolicy clientAuthenticationPolicy = SecureClientAuthPolicy.Required);
        public static ref NetworkSettings WithSecureServerParameters(this ref NetworkSettings settings, ref FixedPEMString certificate, ref FixedPEMString privateKey, ref FixedPEMString caCertificate, ref Unity.Collections.FixedString512Bytes clientName, SecureClientAuthPolicy clientAuthenticationPolicy = SecureClientAuthPolicy.Required);
