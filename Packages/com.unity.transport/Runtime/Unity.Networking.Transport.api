namespace Unity.Networking.Transport.Utilities
{
    public enum ApplyMode : byte
    {
        ReceivedPacketsOnly = 0,
        SentPacketsOnly = 1,
        AllPackets = 2,
        Off = 3,
    }

    public static class FragmentationStageParameterExtensions
    {
        public static FragmentationUtility.Parameters GetFragmentationStageParameters(this ref NetworkSettings settings);
        public static ref NetworkSettings WithFragmentationStageParameters(this ref NetworkSettings settings, int payloadCapacity = 4096);
    }

    public struct FragmentationUtility
    {
        public struct Parameters : INetworkParameter
        {
            public int PayloadCapacity;
            public bool Validate();
        }
    }

    public static class ReliableStageParameterExtensions
    {
        public static ReliableUtility.Parameters GetReliableStageParameters(this ref NetworkSettings settings);
        public static ref NetworkSettings WithReliableStageParameters(this ref NetworkSettings settings, int windowSize = 32, int minimumResendTime = 64, int maximumResendTime = 200);
    }

    public struct ReliableUtility
    {
        public const int DefaultMaximumResendTime = 200;
        public const int DefaultMinimumResendTime = 64;
        [System.Obsolete(@"Renamed to DefaultMaximumResendTime. (UnityUpgradable) -> DefaultMaximumResendTime")] public const int MaximumResendTime = 200;
        public static void SetMaximumResendTime(int value, NetworkDriver driver, NetworkPipeline pipeline, NetworkConnection connection);
        public static void SetMinimumResendTime(int value, NetworkDriver driver, NetworkPipeline pipeline, NetworkConnection connection);
        public struct Parameters : INetworkParameter
        {
            public int MaximumResendTime;
            public int MinimumResendTime;
            public int WindowSize;
            public bool Validate();
        }
        public struct RTTInfo
        {
            public int LastRtt;
            public int ResendTimeout;
            public float SmoothedRtt;
            public float SmoothedVariance;
        }
        public struct SharedContext
        {
            public int MaximumResendTime;
            public int MinimumResendTime;
            public ReliableUtility.RTTInfo RttInfo;
            public ReliableUtility.Statistics stats;
            public int WindowSize;
        }
        public struct Statistics
        {
            public int PacketsDropped;
            public int PacketsDuplicated;
            public int PacketsOutOfOrder;
            public int PacketsReceived;
            public int PacketsResent;
            public int PacketsSent;
            public int PacketsStale;
        }
    }

    public static class SimulatorStageParameterExtensions
    {
        public static SimulatorUtility.Parameters GetSimulatorStageParameters(this ref NetworkSettings settings);
        public static void ModifySimulatorStageParameters(this NetworkDriver driver, SimulatorUtility.Parameters newParams);
        public static ref NetworkSettings WithSimulatorStageParameters(this ref NetworkSettings settings, int maxPacketCount, int maxPacketSize = 1472, ApplyMode mode = ApplyMode.AllPackets, int packetDelayMs = 0, int packetJitterMs = 0, int packetDropInterval = 0, int packetDropPercentage = 0, int packetDuplicationPercentage = 0, int fuzzFactor = 0, int fuzzOffset = 0, uint randomSeed = 0);
    }

    public static class SimulatorUtility
    {
        public struct Parameters : INetworkParameter
        {
            public int FuzzFactor;
            public int FuzzOffset;
            public int MaxPacketCount;
            public int MaxPacketSize;
            public ApplyMode Mode;
            public int PacketDelayMs;
            public int PacketDropInterval;
            public int PacketDropPercentage;
            public int PacketDuplicationPercentage;
            public int PacketJitterMs;
            public uint RandomSeed;
            public bool Validate();
        }
    }
}
