        public static ref NetworkSettings WithSecureClientParameters(this ref NetworkSettings settings, string certificate, string privateKey, string caCertificate, string serverName);
        public static ref NetworkSettings WithSecureClientParameters(this ref NetworkSettings settings, ref Unity.Collections.FixedString4096Bytes certificate, ref Unity.Collections.FixedString4096Bytes privateKey, ref Unity.Collections.FixedString4096Bytes caCertificate, ref Unity.Collections.FixedString512Bytes serverName);
        public static ref NetworkSettings WithSecureClientParameters(this ref NetworkSettings settings, ref FixedPEMString certificate, ref FixedPEMString privateKey, ref FixedPEMString caCertificate, ref Unity.Collections.FixedString512Bytes serverName);
        public static ref NetworkSettings WithSecureServerParameters(this ref NetworkSettings settings, string certificate, string privateKey);
        public static ref NetworkSettings WithSecureServerParameters(this ref NetworkSettings settings, ref Unity.Collections.FixedString4096Bytes certificate, ref Unity.Collections.FixedString4096Bytes privateKey);
