    public struct FixedPEMString
    {
        public const int MaxLength = 16383;
        public int Length { get; }
        public FixedPEMString(string pem) {}
    }

    public enum SecureClientAuthPolicy : uint
    {
        None = 0,
        Optional = 1,
        Required = 2,
    }

