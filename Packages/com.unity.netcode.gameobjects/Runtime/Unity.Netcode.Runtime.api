    [UnityEngine.AddComponentMenu(@"Netcode/Network Transform")] [UnityEngine.DisallowMultipleComponent] [UnityEngine.HelpURL(@"https://docs.unity3d.com/Packages/com.unity.netcode.gameobjects@latest/?subfolder=/manual/components/helper/networktransform.html")] public class NetworkTransform : NetworkBehaviour
    {
        [UnityEngine.Tooltip(@"Selects who has authority (sends state updates) over the transform. If server (the default), then only server-side adjustments to the transform will be synchronized with clients. If owner (or client), then only the owner-side adjustments to the transform will be synchronized with both the server and other clients.")] public NetworkTransform.AuthorityModes AuthorityMode;
        public bool AutoOwnerAuthorityTickOffset = true;
        [UnityEngine.Tooltip(@"Sets whether this transform should sync in local space or in world space")] public bool InLocalSpace;
        public bool Interpolate = true;
        public static int InterpolationBufferTickOffset;
        protected NetworkTransform.AddLogEntryHandler m_AddLogEntry;
        protected NetworkManager m_CachedNetworkManager;
        public NetworkTransform.OnClientRequestChangeDelegate OnClientRequestChange;
        [UnityEngine.Tooltip(@"Lerping yields a traditional linear result where smooth dampening will adjust based on the rate of change. You can mix interpolation types for position, rotation, and scale.")] public NetworkTransform.InterpolationTypes PositionInterpolationType;
        public bool PositionLerpSmoothing = true;
        [UnityEngine.Range(0.01f, 1f)] [UnityEngine.Tooltip(@"The higher the value the smoother, but can result in lost data points (i.e. quick changes in direct). The lower the value the more accurate/precise, but can result in slight stutter (i.e. due to jitter, latency, or a high threshold value).")] public float PositionMaxInterpolationTime = 0.1f;
        public float PositionThreshold = 0.001f;
        public const float PositionThresholdDefault = 0.001f;
        [UnityEngine.Range(1E-05f, 360f)] public float RotAngleThreshold = 0.01f;
        public const float RotAngleThresholdDefault = 0.01f;
        [UnityEngine.Tooltip(@"Lerping yields a traditional linear result where smooth dampening will adjust based on the rate of change. You can mix interpolation types for position, rotation, and scale.")] public NetworkTransform.InterpolationTypes RotationInterpolationType;
        public bool RotationLerpSmoothing = true;
        [UnityEngine.Range(0.01f, 1f)] [UnityEngine.Tooltip(@"The higher the value the smoother, but can result in lost data points (i.e. quick changes in direct). The lower the value the more accurate/precise, but can result in slight stutter (i.e. due to jitter, latency, or a high threshold value).")] public float RotationMaxInterpolationTime = 0.1f;
        [UnityEngine.Tooltip(@"Lerping yields a traditional linear result where smooth dampening will adjust based on the rate of change. You can mix interpolation types for position, rotation, and scale.")] public NetworkTransform.InterpolationTypes ScaleInterpolationType;
        public bool ScaleLerpSmoothing = true;
        [UnityEngine.Range(0.01f, 1f)] [UnityEngine.Tooltip(@"The higher the value the smoother, but can result in lost data points (i.e. quick changes in direct). The lower the value the more accurate/precise, but can result in slight stutter (i.e. due to jitter, latency, or a high threshold value).")] public float ScaleMaxInterpolationTime = 0.1f;
        public float ScaleThreshold = 0.01f;
        public const float ScaleThresholdDefault = 0.01f;
        [UnityEngine.Tooltip(@"When enabled the position interpolator will Slerp towards its current target position.")] public bool SlerpPosition;
        [UnityEngine.Tooltip(@"When enabled, NetworkTransform controls world or local space settings while also providing smooth parenting transitions.When disabled, world or local space settings have to be adjusted by script or in the inspector view.")] public bool SwitchTransformSpaceWhenParented;
        public bool SyncPositionX = true;
        public bool SyncPositionY = true;
        public bool SyncPositionZ = true;
        public bool SyncRotAngleX = true;
        public bool SyncRotAngleY = true;
        public bool SyncRotAngleZ = true;
        public bool SyncScaleX = true;
        public bool SyncScaleY = true;
        public bool SyncScaleZ = true;
        [UnityEngine.Tooltip(@"When enabled, any parented children of this instance will send a state update when this instance sends a state update. If this instance doesn't send a state update, the children will still send state updates when reaching their axis specified threshold delta. Children do not have to have this setting enabled.")] public bool TickSyncChildren;
        [UnityEngine.Tooltip(@"When enabled, this will use half float precision values for position (uses delta position updating), rotation (except when Quaternion compression is enabled), and scale.")] public bool UseHalfFloatPrecision;
        [UnityEngine.Tooltip(@"When enabled, this uses a smallest three implementation that reduces full Quaternion updates down to the size of an unsigned integer (ignores half float precision settings).")] public bool UseQuaternionCompression;
        [UnityEngine.Tooltip(@"When enabled, this will synchronize the full Quaternion (i.e. all Euler rotation axis are updated if one axis has a delta)")] public bool UseQuaternionSynchronization;
        [UnityEngine.Tooltip(@"When set, NetworkTransform will send common state updates using unreliable network delivery to provide a higher tolerance to poor network conditions (especially packet loss). When disabled, all state updates are sent using reliable fragmented sequenced network delivery. Note: This will change the order of operations between transform state updates and other messages sent reliably.")] public bool UseUnreliableDeltas;
        public bool CanCommitToTransform { get; protected set; }
        protected bool PositionInLocalSpace { get; }
        protected bool RotationInLocalSpace { get; }
        public NetworkTransform() {}
        protected override string __getTypeName();
        protected override void __initializeRpcs();
        protected override void __initializeVariables();
        protected void ApplyAuthoritativeState();
        protected virtual void Awake();
        protected NetworkDeltaPosition GetHalfPositionState();
        public UnityEngine.Vector3 GetScale(bool getCurrentState = false);
        public UnityEngine.Vector3 GetSpaceRelativePosition(bool getCurrentState = false);
        public UnityEngine.Quaternion GetSpaceRelativeRotation(bool getCurrentState = false);
        protected int GetStateId(ref NetworkTransform.NetworkTransformState state);
        public static float GetTickLatency();
        public static float GetTickLatencyInSeconds();
        protected void Initialize();
        protected override void InternalOnNetworkPostSpawn();
        protected override void InternalOnNetworkSessionSynchronized();
        public bool IsServerAuthoritative();
        protected virtual void OnAuthorityPushTransformState(ref NetworkTransform.NetworkTransformState networkTransformState);
        protected virtual void OnBeforeUpdateTransformState();
        public override void OnDestroy();
        public virtual void OnFixedUpdate();
        public override void OnGainedOwnership();
        protected virtual void OnInitialize(ref NetworkTransform.NetworkTransformState replicatedState);
        protected virtual void OnInitialize(ref Unity.Netcode.NetworkVariable<NetworkTransform.NetworkTransformState> replicatedState);
        protected virtual bool OnIsServerAuthoritative();
        public override void OnLostOwnership();
        public override void OnNetworkDespawn();
        public override void OnNetworkObjectParentChanged(NetworkObject parentNetworkObject);
        public override void OnNetworkSpawn();
        protected virtual void OnNetworkTransformStateUpdated(ref NetworkTransform.NetworkTransformState oldState, ref NetworkTransform.NetworkTransformState newState);
        protected override void OnOwnershipChanged(ulong previous, ulong current);
        protected override void OnSynchronize<T>(ref Unity.Netcode.BufferSerializer<T> serializer) where T : IReaderWriter;
        protected virtual void OnTransformUpdated();
        public virtual void OnUpdate();
        public void SetMaxInterpolationBound(float maxInterpolationBound);
        public void SetState(System.Nullable<UnityEngine.Vector3> posIn = default(System.Nullable<UnityEngine.Vector3>), System.Nullable<UnityEngine.Quaternion> rotIn = default(System.Nullable<UnityEngine.Quaternion>), System.Nullable<UnityEngine.Vector3> scaleIn = default(System.Nullable<UnityEngine.Vector3>), bool teleportDisabled = true);
        public void Teleport(UnityEngine.Vector3 newPosition, UnityEngine.Quaternion newRotation, UnityEngine.Vector3 newScale);
        protected delegate void AddLogEntryHandler(ref NetworkTransform.NetworkTransformState networkTransformState, ulong targetClient, bool preUpdate = false);
        public enum AuthorityModes
        {
            Server = 0,
            Owner = 1,
        }
        public enum InterpolationTypes
        {
            LegacyLerp = 0,
            Lerp = 1,
            SmoothDampening = 2,
        }
        public struct NetworkTransformState : INetworkSerializable
        {
            public bool HasPositionChange { get; }
            public bool HasPositionX { get; }
            public bool HasPositionY { get; }
            public bool HasPositionZ { get; }
            public bool HasRotAngleChange { get; }
            public bool HasRotAngleX { get; }
            public bool HasRotAngleY { get; }
            public bool HasRotAngleZ { get; }
            public bool HasScaleChange { get; }
            public bool HasScaleX { get; }
            public bool HasScaleY { get; }
            public bool HasScaleZ { get; }
            public bool InLocalSpace { get; }
            public bool IsSynchronizing { get; }
            public bool IsTeleportingNextFrame { get; }
            public int LastSerializedSize { get; }
            public bool QuaternionCompression { get; }
            public bool QuaternionSync { get; }
            public bool UseHalfFloatPrecision { get; }
            public bool UseInterpolation { get; }
            public bool UsePositionSlerp { get; }
            public bool WasTeleported { get; }
            public int GetNetworkTick();
            public UnityEngine.Vector3 GetPosition();
            public UnityEngine.Quaternion GetRotation();
            public UnityEngine.Vector3 GetScale();
            public bool IsReliableStateUpdate();
            public bool IsUnreliableFrameSync();
            public void NetworkSerialize<T>(Unity.Netcode.BufferSerializer<T> serializer) where T : IReaderWriter;
        }
        public delegate System.ValueTuple<UnityEngine.Vector3, UnityEngine.Quaternion, UnityEngine.Vector3> OnClientRequestChangeDelegate(UnityEngine.Vector3 pos, UnityEngine.Quaternion rot, UnityEngine.Vector3 scale);
    }

