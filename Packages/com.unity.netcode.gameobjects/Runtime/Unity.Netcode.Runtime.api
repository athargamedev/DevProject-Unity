            [UnityEngine.SerializeField] [UnityEngine.Tooltip(@"Percentage of sent and received packets to drop. Only applies in the editor and in the editor and in developments builds.")] public int PacketDropRate;
            [UnityEngine.SerializeField] [UnityEngine.Tooltip(@"Jitter (random variation) to add/substract to the packet delay (in milliseconds). Only applies in the editor and in development builds. The value is ignored in production builds.")] public int PacketJitterMS;
        }
    }
