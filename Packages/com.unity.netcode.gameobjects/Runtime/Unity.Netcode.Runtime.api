    [UnityEngine.AddComponentMenu(@"Netcode/Network Object", -99)] [UnityEngine.DisallowMultipleComponent] [UnityEngine.HelpURL(@"https://docs.unity3d.com/Packages/com.unity.netcode.gameobjects@latest/?subfolder=/manual/components/core/networkobject.html")] public sealed class NetworkObject : UnityEngine.MonoBehaviour
    {
        [UnityEngine.Tooltip(@"When enabled (default disabled), spawned instances of this NetworkObject will automatically migrate to any newly assigned active scene.")] public bool ActiveSceneSynchronization;
        [UnityEngine.Tooltip(@"When enabled (default disabled), owner's can parent a NetworkObject locally without having to send an RPC to the server or host. Only pertinent when using client-server network topology configurations.")] public bool AllowOwnerToParent;
        [UnityEngine.Tooltip(@"If enabled (default disabled), instances of this NetworkObject will ignore any parent(s) it might have and replicate on clients as the root being its parent.")] public bool AlwaysReplicateAsRoot;
        [UnityEngine.Tooltip(@"When disabled (default enabled), NetworkObject parenting will not be automatically synchronized. This is typically used when you want to implement your own custom parenting solution.")] public bool AutoObjectParentSync = true;
        public NetworkObject.VisibilityDelegate CheckObjectVisibility;
        [UnityEngine.HideInInspector] public int DeferredDespawnTick;
        [UnityEngine.Tooltip(@"When enabled (default disabled), instances of this NetworkObject will not be destroyed if the owning client disconnects.")] public bool DontDestroyWithOwner;
        public NetworkObject.SpawnDelegate IncludeTransformWhenSpawning;
        public NetworkObject.OnDeferedDespawnCompleteDelegateHandler OnDeferredDespawnComplete;
        public System.Action OnMigratedToNewScene;
