  m_BoredKeywords:
  - bored
  - boring
  - not interested
  - nothing to do
  - tired of this
  m_BoredLightColor: {r: 0, g: 0, b: 1, a: 1}
  m_BoredLightIntensity: 1.2
  m_LightTransitionSeconds: 0.4
