    - target: {fileID: 114591927686108806, guid: ee8ad5531e02f4f0eb2d4187ec62c699, type: 3}
      propertyPath: m_text
      value: "This effect uses multiple particle systems and a custom shader. The
        Particle System and shader are controlled with a script to make them play
        at the same time. \nThere are two shaders; Dissolve (ball) which uses a greyscale
