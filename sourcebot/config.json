{
  "$schema": "https://raw.githubusercontent.com/sourcebot-dev/sourcebot/main/schemas/v3/index.json",
  "contexts": {
    "gameplay": {
      "include": ["github.com/atharandre02-arch/DevProject"],
      "description": "Unity DevProject — all gameplay code, dialogue, effects, networking"
    },
    "mlagents-sdk": {
      "include": ["github.com/athargamedev/ml-agents"],
      "description": "ML-Agents SDK — Python trainers, C# runtime, SideChannels"
    }
  },
  "connections": {
    "devproject-local": {
      "type": "git",
      "url": "file:///repos/devproject",
      "revisions": {
        "branches": [
          "main"
        ]
      }
    },
    "ml-agents-local": {
      "type": "git",
      "url": "file:///repos/ml-agents",
      "revisions": {
        "branches": [
          "develop",
          "main"
        ]
      }
    }
  },
  "models": [
    {
      "provider": "openai-compatible",
      "model": "llama-3.2-3b-instruct@q8_0",
      "displayName": "Llama 3.2 3B (Default — fast agent loops)",
      "baseUrl": "http://lmstudio-proxy:8080/v1",
      "token": {
        "env": "LM_STUDIO_TOKEN"
      }
    },
    {
      "provider": "openai-compatible",
      "model": "qwen3-8b",
      "displayName": "Qwen3 8B (Deep analysis — slow, use via web UI)",
      "baseUrl": "http://lmstudio-proxy:8080/v1",
      "token": {
        "env": "LM_STUDIO_TOKEN"
      }
    },
    {
      "provider": "openai-compatible",
      "model": "qwen2.5-coder-7b-instruct@q8_0",
      "displayName": "Qwen2.5 Coder 7B (code-only, avoid prose)",
      "baseUrl": "http://lmstudio-proxy:8080/v1",
      "token": {
        "env": "LM_STUDIO_TOKEN"
      }
    }
  ],
  "settings": {
    "maxFileSize": 1048576,
    "maxTrigramCount": 20000,
    "reindexIntervalMs": 3600000
  }
}
