{
  "mcpServers": {
    "filesystem": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\DevProject"
      ],
      "alwaysAllow": [
        "read_file",
        "read_text_file",
        "read_multiple_files",
        "write_file",
        "edit_file",
        "list_directory",
        "create_directory",
        "list_directory_with_sizes",
        "move_file",
        "search_files",
        "get_file_info",
        "list_allowed_directories",
        "directory_tree",
        "read_media_file"
      ]
    },
    "serena-mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "D:\\DevProject"
      ]
    },
    "sequentialthinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "unityMCP": {
      "command": "cmd",
      "args": [
        "/c",
        "cd /d D:\\GithubRepos\\unity-mcp-beta\\Server && uv run src/main.py --transport stdio --default-instance DevProject"
      ]
    },
    "blender": {
      "command": "uvx",
      "args": [
        "blender-mcp"
      ]
    },
    "mixamo": {
      "command": "python",
       "args": ["-m", "mixamo_mcp.server"],
       "env": {
       "PYTHONPATH": "d:/GithubRepos/unity-mcp-mixamo/Server/src"
      }
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@0.1.38",
        "http://127.0.0.1:54323/api/mcp",
        "--header",
        "Authorization:Bearer sb_secret_N7UND0UgjKTVK-Uodkm0Hg_xSvEMPvz"
      ]
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--init",
        "--pull=always",
        "--env-file",
        "D:\\DevProject\\.env",
        "mcp/sonarqube"
      ]
    }
  }
}
