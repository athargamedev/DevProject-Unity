{
  "mcpServers": {
    "sourcebot": {
     "type": "http",
     "url": "http://127.0.0.1:8090/api/mcp",
     "headers": {
       "Authorization": "Bearer sbk_229f313179e67cdc1cb7af550ed248986b7c9595fbf5dca7380d8c2b42dad493",
       "Accept": "application/json, text/event-stream"
     }
   },
    "filesystem": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\DevProject"
      ],
      "alwaysAllow": [
        "read_file",
        "read_text_file",
        "read_multiple_files",
        "write_file",
        "edit_file",
        "list_directory",
        "create_directory",
        "list_directory_with_sizes",
        "move_file",
        "search_files",
        "get_file_info",
        "list_allowed_directories",
        "directory_tree",
        "read_media_file"
      ]
    },
    "serena-mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "D:\\DevProject"
      ]
    },
    "sequentialthinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "unityMCP": {
      "command": "cmd",
      "args": [
        "/c",
        "cd /d D:\\GithubRepos\\unity-mcp-beta\\Server && uv run src/main.py --transport stdio --default-instance DevProject"
      ]
    },
    "blender": {
      "command": "uvx",
      "args": [
        "blender-mcp"
      ]
    },
    "mixamo": {
      "command": "python",
       "args": ["-m", "mixamo_mcp.server"],
       "env": {
       "PYTHONPATH": "d:/GithubRepos/unity-mcp-mixamo/Server/src"
      }
    }
  }
}  
