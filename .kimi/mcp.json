{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--allow-unrestricted-file-access"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@latest"
      ]
    },
    "serena-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project",
        "D:\\DevProject"
      ]
    },
    "unityMCP": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "D:\\GithubRepos\\unity-mcp-beta\\Server",
        "src/main.py",
        "--transport",
        "stdio",
        "--default-instance",
        "DevProject"
      ]
    }
  }
}
